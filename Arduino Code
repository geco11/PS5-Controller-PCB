#include <Joystick.h>
#include <Keyboard.h>

Joystick_ Joystick(
  JOYSTICK_DEFAULT_REPORT_ID,
  JOYSTICK_TYPE_JOYSTICK,
  12,
  0,
  true, true, true,
  true, true, false,
  false, false, false,
  false, false
);

// =========================
// CALIBRATION PER AXIS
// enter real values for each axis
// =========================
#define A0_MIN     0
#define A0_CENTER  520
#define A0_MAX     1023

#define A1_MIN     0
#define A1_CENTER  522
#define A1_MAX     1023

#define A2_MIN     0
#define A2_CENTER  511
#define A2_MAX     1023

#define A3_MIN     0
#define A3_CENTER  515
#define A3_MAX     1023

// =========================
// OUTPUT RANGE
// =========================
#define OUT_MIN     0
#define OUT_MAX     1023
#define OUT_CENTER  511

// =========================
// SMALL ADJUSTMENTS
// =========================
#define RIGHT_Y_OFFSET  -2
#define SMOOTH_ALPHA    0.20

// =========================
// SPECIAL BUTTON INDEXES
// =========================
#define LU_INDEX 1
#define LD_INDEX 3

// =========================
// SMOOTH STATE
// =========================
float smoothLX = OUT_CENTER;
float smoothLY = OUT_CENTER;
float smoothRX = OUT_CENTER;
float smoothRY = OUT_CENTER;
float smoothZ  = OUT_CENTER;

bool lastLuPressed = false;
bool lastLdPressed = false;

// =========================
// PIECEWISE CALIBRATION
// maps MIN -> 0, CENTER -> 511, MAX -> 1023
// =========================
int mapCalibratedAxis(int raw, int inMin, int inCenter, int inMax) {
  if (raw < inMin) raw = inMin;
  if (raw > inMax) raw = inMax;

  long result;

  if (raw <= inCenter) {
    result = map(raw, inMin, inCenter, OUT_MIN, OUT_CENTER);
  } else {
    result = map(raw, inCenter, inMax, OUT_CENTER, OUT_MAX);
  }

  if (result < OUT_MIN) result = OUT_MIN;
  if (result > OUT_MAX) result = OUT_MAX;

  return (int)result;
}

// =========================
// SMOOTHING
// =========================
int smoothValue(float &state, int target) {
  state = state + (target - state) * SMOOTH_ALPHA;

  if (state < OUT_MIN) state = OUT_MIN;
  if (state > OUT_MAX) state = OUT_MAX;

  return (int)state;
}

// =========================
// BUTTONS
// =========================
const int pins[12] = {
  8,   // Ltr
  9,   // Lu -> keyboard backtick + controller button
  10,  // Ll
  14,  // Ld -> keyboard backslash + controller button
  16,  // Lr
  15,  // Ljoy
  7,   // Rtr
  4,   // Ru
  3,   // Rr
  5,   // Rd
  6,   // Rl
  2    // Rjoy
};

const int btnNr[12] = {
  6,   // Ltr
  8,   // Lu
  4,   // Ll
  9,  // Ld
  5,   // Lr
  10,  // Ljoy
  7,   // Rtr
  3,   // Ru
  1,   // Rr
  0,   // Rd
  2,   // Rl
  11   // Rjoy
};

void setup() {
  for (int i = 0; i < 12; i++) {
    pinMode(pins[i], INPUT_PULLUP);
  }

  pinMode(A0, INPUT);
  pinMode(A1, INPUT);
  pinMode(A2, INPUT);
  pinMode(A3, INPUT);

  Joystick.begin();
  Keyboard.begin();

  Joystick.setXAxisRange(OUT_MIN, OUT_MAX);
  Joystick.setYAxisRange(OUT_MIN, OUT_MAX);
  Joystick.setZAxisRange(OUT_MIN, OUT_MAX);
  Joystick.setRxAxisRange(OUT_MIN, OUT_MAX);
  Joystick.setRyAxisRange(OUT_MIN, OUT_MAX);
}

void loop() {
  // =========================
  // LEFT STICK
  // A2 = LX, A3 = LY
  // inverted
  // =========================
  int lxRaw = analogRead(A2);
  int lyRaw = analogRead(A3);

  int lxTarget = OUT_MAX - mapCalibratedAxis(lxRaw, A2_MIN, A2_CENTER, A2_MAX);
  int lyTarget = OUT_MAX - mapCalibratedAxis(lyRaw, A3_MIN, A3_CENTER, A3_MAX);

  Joystick.setXAxis(smoothValue(smoothLX, lxTarget));
  Joystick.setYAxis(smoothValue(smoothLY, lyTarget));

  // =========================
  // RIGHT STICK X
  // A1 = RX
  // inverted
  // =========================
  int rxRaw = analogRead(A1);
  int rxTarget = OUT_MAX - mapCalibratedAxis(rxRaw, A1_MIN, A1_CENTER, A1_MAX);

  Joystick.setRxAxis(smoothValue(smoothRX, rxTarget));

  // =========================
  // RIGHT STICK Y
  // A0 = RY
  // inverted + offset
  // =========================
  int ryRaw = analogRead(A0);
  int ryTarget = OUT_MAX - mapCalibratedAxis(ryRaw, A0_MIN, A0_CENTER, A0_MAX);
  ryTarget += RIGHT_Y_OFFSET;

  if (ryTarget < OUT_MIN) ryTarget = OUT_MIN;
  if (ryTarget > OUT_MAX) ryTarget = OUT_MAX;

  Joystick.setRyAxis(smoothValue(smoothRY, ryTarget));

  // =========================
  // Z AXIS / SLIDER
  // using A0 reversed
  // =========================
  int zTarget = mapCalibratedAxis(1023 - ryRaw, 0, 1023 - A0_CENTER, 1023);
  Joystick.setZAxis(smoothValue(smoothZ, zTarget));

  // =========================
  // BUTTONS
  // =========================
  for (int i = 0; i < 12; i++) {
    bool pressed = !digitalRead(pins[i]);

    // LU = keyboard + controller button
    if (i == LU_INDEX) {
      if (pressed && !lastLuPressed) {
        Keyboard.press('`');
      }
      if (!pressed && lastLuPressed) {
        Keyboard.release('`');
      }
      lastLuPressed = pressed;

      if (pressed) {
        Joystick.pressButton(btnNr[i]);
      } else {
        Joystick.releaseButton(btnNr[i]);
      }
    }

    // LD = keyboard + controller button
    else if (i == LD_INDEX) {
      if (pressed && !lastLdPressed) {
        Keyboard.press('\\');
      }
      if (!pressed && lastLdPressed) {
        Keyboard.release('\\');
      }
      lastLdPressed = pressed;

      if (pressed) {
        Joystick.pressButton(btnNr[i]);
      } else {
        Joystick.releaseButton(btnNr[i]);
      }
    }

    // all other buttons = normal controller buttons
    else {
      if (pressed) {
        Joystick.pressButton(btnNr[i]);
      } else {
        Joystick.releaseButton(btnNr[i]);
      }
    }
  }

  delay(5);
}
